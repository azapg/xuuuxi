{
  "name": "@xuuuxi/server",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build ./src/index.ts --target=bun --outfile=dist/server.js",
    "start": "bun dist/server.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@xuuuxi/shared": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.44",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31"
  }
}
